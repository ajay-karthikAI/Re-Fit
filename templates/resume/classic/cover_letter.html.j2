<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ resume.contact.full_name }} Cover Letter</title>
  <style>
    @page {
      size: Letter;
      margin: {{ margin_in }}in;
      {% if show_page_numbers %}
      @bottom-center {
        content: "Page " counter(page) " of " counter(pages);
        color: #666;
        font-family: {{ font_stack | safe }};
        font-size: 8pt;
      }
      {% endif %}
    }

    * {
      box-sizing: border-box;
    }

    body {
      color: #202020;
      font-family: {{ font_stack | safe }};
      font-size: {{ base_font_size }}pt;
      line-height: 1.42;
      margin: 0;
    }

    h1,
    p {
      margin: 0;
    }

    .header {
      border-bottom: 1.4pt solid {{ accent_color }};
      margin-bottom: 0.3in;
      padding-bottom: 0.08in;
      text-align: center;
    }

    .name {
      color: #111;
      font-family: {{ heading_font_stack | safe }};
      font-size: {{ base_font_size + 8 }}pt;
      font-weight: 700;
      letter-spacing: 0.5pt;
      line-height: 1.05;
      text-transform: uppercase;
    }

    .contact {
      color: #333;
      font-size: {{ base_font_size - 1 }}pt;
      margin-top: 0.04in;
    }

    .letter p {
      margin-bottom: 0.14in;
    }
  </style>
</head>
<body>
  <header class="header">
    <h1 class="name">{{ resume.contact.full_name }}</h1>
    <p class="contact">{{ contact_line }}</p>
  </header>

  <main class="letter">
    {% for paragraph in paragraphs %}
    <p>{{ paragraph }}</p>
    {% endfor %}
  </main>
</body>
</html>
